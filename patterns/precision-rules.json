{
  "schema": 1,
  "description": "确定性护栏契约(guardrail):供 precision/recall 测试加载,校验正则提示层调得准不准。绿 != skill 正确 —— 模型实际按散文层判断,模型级评测见 tests/golden/。",
  "canonical_source": "对模型而言,patterns/banned-words.md 与 patterns/user-taste.md 的散文规则是唯一事实来源;本 JSON 是从散文派生的护栏镜像,新增规则须在散文层有对应条目。",
  "calibration": {"profile": "通用主力 LLM(GPT-4/5 系、Claude 4 系)", "last_reviewed": "2026-06-18", "note": "AI 味词汇随模型迭代演化,floor 与词表需按当前主力模型定期复核"},
  "documentation": [
    {
      "path": "patterns/banned-words.md",
      "required_markers": [
        "不做裸字符串定罪",
        "假坦诚开场",
        "格言公式 / 伪洞察枢纽",
        "连续短句造戏剧感",
        "标题后复述标题",
        "变更叙事腔",
        "助手续写尾巴",
        "I/J 不并入 AI 味分",
        "检测下限(floor)",
        "否定先行密度门控",
        "词表校准"
      ]
    },
    {
      "path": "patterns/catalog/patterns.md",
      "required_markers": [
        "22b. 格言公式 / 伪洞察枢纽",
        "23a. 标题后复述标题",
        "23b. 变更叙事腔",
        "26a. 助手续写尾巴",
        "27a. 假坦诚开场",
        "连续短句造戏剧感",
        "不得拿来断言作者身份"
      ]
    }
  ],
  "rules": [
    {
      "id": "workflow_placeholder",
      "axis": "risk",
      "kind": "regex",
      "regex": "\\[(?:产品名|品牌|作者|负责人|项目名)\\]|\\{\\{[^}]+\\}\\}|(?<![A-Za-z])X{2,}(?![A-Za-z])|XXXX-XX-XX"
    },
    {
      "id": "workflow_url",
      "axis": "risk",
      "kind": "regex",
      "regex": "[?&](?:utm_[^=]+|referrer)="
    },
    {
      "id": "format_markdown",
      "axis": "risk",
      "kind": "regex",
      "contexts": ["plain_text"],
      "regex": "(?:^|\\n)#{1,6} |\\*\\*.+?\\*\\*|`[^`]+`"
    },
    {
      "id": "dash_overuse",
      "axis": "pattern",
      "kind": "regex_count",
      "regex": "——",
      "min_count": 2,
      "required_regex": "也就是|换句话说|或者说",
      "excluded_contexts": ["narrative", "brand_copy"]
    },
    {
      "id": "english_audience_mismatch",
      "axis": "pattern",
      "kind": "term_count",
      "contexts": ["public_general"],
      "terms": ["check", "feature", "workflow", "deadline", "context", "state", "cache", "argument", "pipeline"],
      "min_count": 3
    },
    {
      "id": "generic_addressee",
      "axis": "pattern",
      "kind": "term_count",
      "contexts": ["single_recipient"],
      "terms": ["用户", "大家", "各位", "朋友们"],
      "min_count": 3
    },
    {
      "id": "mechanical_parallel",
      "axis": "pattern",
      "kind": "regex",
      "regex": "首先[\\s\\S]+其次[\\s\\S]+最后",
      "excluded_contexts": ["formal_enumeration"]
    },
    {
      "id": "fake_candor",
      "axis": "pattern",
      "requires_adjacent_negative": true,
      "kind": "regex",
      "regex": "^(?:说实话|坦白讲|我本来不想说)",
      "excluded_regex": "(?:去年|上周|我错|利益冲突|无法确认|没核实|记不清|不确定|代价|失败)"
    },
    {
      "id": "pseudo_insight",
      "axis": "pattern",
      "requires_adjacent_negative": true,
      "kind": "regex",
      "regex": "归根结底[\\s\\S]*(?:真正的|不是[\\s\\S]+而是)",
      "excluded_regex": "(?:因为|数据显示|具体来说|例如|证据是|原因是)"
    },
    {
      "id": "dramatic_short_run",
      "axis": "pattern",
      "requires_adjacent_negative": true,
      "kind": "short_sentence_run",
      "max_chars": 5,
      "min_count": 3,
      "excluded_contexts": ["brand_copy"]
    },
    {
      "id": "title_restatement",
      "axis": "pattern",
      "requires_adjacent_negative": true,
      "kind": "title_restatement",
      "excluded_contexts": ["news_lede", "academic_abstract", "legal_summary"]
    },
    {
      "id": "change_narration",
      "axis": "pattern",
      "requires_adjacent_negative": true,
      "kind": "regex",
      "contexts": ["publishable_copy"],
      "regex": "这次我把|下面[\\s\\S]+调整了|改完后|读起来会更"
    },
    {
      "id": "assistant_tail",
      "axis": "pattern",
      "requires_adjacent_negative": true,
      "kind": "regex",
      "contexts": ["publishable_copy"],
      "regex": "如果你愿意|需要的话我可以|我还可以再给你"
    },
    {
      "id": "empty_business_jargon",
      "axis": "pattern",
      "kind": "term_count",
      "contexts": ["vague_business"],
      "terms": ["拆解", "接住", "落地", "闭环", "势能"],
      "min_count": 3
    },
    {
      "id": "cliche_opener",
      "axis": "pattern",
      "kind": "regex",
      "regex": "随着[\\s\\S]{0,24}(?:不断|持续|快速)?(?:发展|深入|推进|到来)|在当今[\\s\\S]{0,12}(?:时代|背景|社会)|在[\\s\\S]{0,24}的大背景下",
      "floor": true
    },
    {
      "id": "summary_cliche",
      "axis": "pattern",
      "kind": "regex",
      "regex": "综上所述|由此可见|总而言之",
      "floor": true
    },
    {
      "id": "empty_emphasis",
      "axis": "pattern",
      "kind": "regex",
      "regex": "值得注意的是|毋庸置疑|不言而喻|众所周知",
      "floor": true
    },
    {
      "id": "pr_empowerment",
      "axis": "pattern",
      "kind": "regex",
      "regex": "赋能|抓手|护航",
      "floor": true
    },
    {
      "id": "negation_first_cluster",
      "axis": "pattern",
      "requires_adjacent_negative": true,
      "kind": "regex_count",
      "regex": "不(?:是|需要)[\\s\\S]{1,20}?(?:而是|而要|要的是)",
      "min_count": 2,
      "excluded_contexts": ["brand_copy"]
    }
  ]
}
